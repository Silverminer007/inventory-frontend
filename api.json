    "schemas": {
      "ContainerDTO": {
        "type": "object",
        "required": ["name", "containerType"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string",
            "pattern": "\\S"
          },
          "description": {
            "type": "string"
          },
          "containerType": {
            "type": "string"
          },
          "locationType": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "position": {
            "type": "string"
          },
          "qrCode": {
            "type": "string"
          },
          "parentContainerId": {
            "type": "integer",
            "format": "int64"
          },
          "lastModified": {
            "$ref": "#/components/schemas/LocalDateTime"
          },
          "version": {
            "type": "integer",
            "format": "int64"
          },
          "createdAt": {
            "$ref": "#/components/schemas/LocalDateTime"
          },
          "locationPath": {
            "type": "string"
          },
          "itemCount": {
            "type": "integer",
            "format": "int32"
          },
          "totalItemCount": {
            "type": "integer",
            "format": "int32"
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContainerDTO"
            }
          },
          "parent": {
            "$ref": "#/components/schemas/ParentInfo"
          }
        }
      },
      "ContainerInfo": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      },
      "ItemDTO": {
        "type": "object",
        "required": ["name", "quantity"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string",
            "pattern": "\\S"
          },
          "description": {
            "type": "string"
          },
          "containerId": {
            "type": "integer",
            "format": "int64"
          },
          "position": {
            "type": "string"
          },
          "quantity": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "barcode": {
            "type": "string"
          },
          "qrCode": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "lastModified": {
            "$ref": "#/components/schemas/LocalDateTime"
          },
          "version": {
            "type": "integer",
            "format": "int64"
          },
          "createdAt": {
            "$ref": "#/components/schemas/LocalDateTime"
          },
          "locationPath": {
            "type": "string"
          },
          "containerType": {
            "type": "string"
          },
          "container": {
            "$ref": "#/components/schemas/ContainerInfo"
          }
        }
      },
      "LocalDateTime": {
        "type": "string",
        "format": "date-time",
        "examples": ["2022-03-10T12:15:50"]
      },
      "MoveRequest": {
        "type": "object",
        "properties": {
          "parentContainerId": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "MoveRequest1": {
        "type": "object",
        "properties": {
          "containerId": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ParentInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "containerType": {
            "type": "string"
          }
        }
      },
      "SynonymDTO": {
        "type": "object",
        "required": ["canonicalTerm", "synonym"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "canonicalTerm": {
            "type": "string",
            "pattern": "\\S"
          },
          "synonym": {
            "type": "string",
            "pattern": "\\S"
          }
        }
      }
    }
